        ],
        "aws_concepts": [
            "Region vs Availability Zone",
            "Shared Responsibility Model",
            "IAM: User vs Role vs Group vs Policy"
        ],
        "quote_of_the_day": get_quote(),
        "disk_usage": get_disk_usage()
    }

    # In ra màn hình
    print("\n" + "="*40)
    print("📊 WEEK 1 SUMMARY — Cloud Engineer Journey")
    print("="*40)
    print(f"📅 Date     : {summary['date']}")
    print(f"✅ Days done: {summary['days_completed']}/7")
    print(f"\n📚 Topics learned:")
